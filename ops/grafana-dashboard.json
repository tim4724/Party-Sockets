        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(party_sockets_connections_total[5m]) * 60",
          "legendFormat": "{{region}} · {{origin}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Rooms created / min (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
