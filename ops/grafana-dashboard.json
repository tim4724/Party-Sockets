    {
      "id": 40,
      "type": "bargauge",
      "title": "Top origins (since-boot connections)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (origin) (party_sockets_connections_total))",
          "legendFormat": "{{origin}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Process uptime per machine",
      "description": "Big drops indicate restarts (often OOM kills).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
